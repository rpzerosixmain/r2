#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bundler/setup'
require 'dotenv/load'
require 'logger'

require 'r2'

# CLI logger; verbosity is controlled by the --verbose flag inside the CLI.
logger = Logger.new($stdout)
logger.level = Logger::ERROR

# Simplified format for CLI output
logger.formatter = proc do |_severity, _datetime, _progname, msg|
  "[R2] #{msg}\n"
end

# Simple dependency injection into the CLI layer.
R2::CLI.logger = logger

begin
  R2::CLI.storage = R2::Storage.new(**R2::Configuration.from_env.to_h)

  R2::CLI.start(ARGV)
rescue R2::Error => e
  # Expected, user-facing failures: log the message and show it concisely.
  logger.error(e.message)
  warn("[R2] #{e.message}")
  exit(1)
rescue StandardError => e
  # Unexpected failures: log the full details for debugging.
  logger.error(e.full_message)
  warn("[R2] #{e.message}")
  exit(1)
end
